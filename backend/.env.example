# ───────── Server ─────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ───────── MSSQL ─────────
# Cú pháp Prisma cho MSSQL:
# sqlserver://HOST:PORT;database=DBNAME;user=USER;password=PASS;trustServerCertificate=true
DATABASE_URL="sqlserver://localhost:1433;database=iot_spms;user=sa;password=YourStrong@Password123;trustServerCertificate=true;encrypt=DANGER_PLAINTEXT"

# ───────── JWT (mock HCMUT_SSO) ─────────
JWT_SECRET=spms_hcmut_secret_key_2025_change_in_production
JWT_EXPIRES_IN=8h

# ───────── External APIs ─────────
HCMUT_SSO_URL=https://sso.hcmut.edu.vn/api
HCMUT_DATACORE_URL=https://datacore.hcmut.edu.vn/api
BKPAY_URL=https://bkpay.hcmut.edu.vn/api
BKPAY_API_KEY=mock_bkpay_secret

# ───────── Performance SLA ─────────
GATE_RESPONSE_TIMEOUT_MS=2000
IOT_UPDATE_TIMEOUT_MS=5000
